# ==============================================================================
# <service-name> — environment template
# Copy to `.env` on the host and fill in. NEVER commit `.env`.
# Conventions: docs/standards/environment-variables.md
# ==============================================================================

# --- Platform (values come from the root .env; repeat only what this stack consumes)
TZ=America/Santiago
PUID=1000
PGID=1000
DOMAIN=
CONFIG_ROOT=/srv/dahouselab/config
DATA_ROOT=/srv/dahouselab/data

# --- Service
# <What this variable controls>
<NAME>_EXAMPLE_SETTING=

# <Secret — generate: openssl rand -base64 32>
<NAME>_SECRET=
