# ==============================================================================
# <service-name> — service-specific environment (ADR-0012)
# Copy to `.env.service` on the host, chmod 600. NEVER commit `.env.service`.
# Platform globals (TZ, DOMAIN, *_ROOT, …) come from the root .env via the
# `.env` symlink — do NOT repeat them here.
# Conventions: docs/standards/environment-variables.md
# ==============================================================================

# <What this variable controls>
<NAME>_EXAMPLE_SETTING=

# <Secret — generate: openssl rand -base64 32; fill with an editor, never echo>
<NAME>_SECRET=
