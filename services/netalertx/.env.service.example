# netalertx — service environment (ADR-0012 layered env files)
# Copy to .env.service (chmod 600) and adjust. Never commit .env.service.
# Platform globals (DOMAIN, TZ, PUID/PGID, CONFIG_ROOT, DATA_ROOT) arrive via
# the .env symlink — do not duplicate them here.
#
# NetAlertX has NO database secret: it uses a local sqlite file under /data.
# The admin login is set in the web UI at first run, not via env.

# --- netalertx ---
PORT=20211   # web UI port (bound on the host; fenced to Caddy via nftables — see the runbook)
