# nextcloud — service environment (ADR-0012 layered env files)
# Copy to .env.service (chmod 600) and fill in. Never commit .env.service.
# Platform globals (DOMAIN, TZ, PUID/PGID, CONFIG_ROOT, DATA_ROOT) arrive via
# the .env symlink — do not duplicate them here.
#
# These use the names the postgres/nextcloud images consume directly, so they
# are passed straight through via env_file (compose does NOT interpolate them).

# --- nextcloud database (Postgres) ---
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud
POSTGRES_PASSWORD=   # Generate: openssl rand -base64 32
