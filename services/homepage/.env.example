# ==============================================================================
# homepage — environment template
# Copy to `.env` on the host and fill in. NEVER commit `.env`.
# Conventions: docs/standards/environment-variables.md
# ==============================================================================

# --- Platform (values come from the root .env)
TZ=America/Santiago
PUID=1000
PGID=1000
DOMAIN=dahub.casa
CONFIG_ROOT=/srv/dahouselab/config

# --- Service
# No service-specific secrets. HOMEPAGE_ALLOWED_HOSTS is derived from DOMAIN in compose.yaml.
