# ==============================================================================
# caddy — service-specific environment (ADR-0012)
# Copy to `.env.service` on the host, chmod 600. NEVER commit `.env.service`.
# Platform globals come from the root .env via the `.env` symlink.
# ==============================================================================

# Cloudflare API token scoped to Zone -> DNS -> Edit on the ${DOMAIN} zone only.
# Used by the caddy-dns/cloudflare plugin for DNS-01 issuance (ADR-0011).
# Canonical plugin name kept as-is (documented deviation from the service-prefix rule).
# Fill with an editor, never echo.
CLOUDFLARE_API_TOKEN=
