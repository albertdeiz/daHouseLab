# ==============================================================================
# caddy — environment template
# Copy to `.env` on the host and fill in. NEVER commit `.env`.
# Conventions: docs/standards/environment-variables.md
# ==============================================================================

# --- Platform (values come from the root .env)
TZ=America/Santiago
DOMAIN=dahub.casa
DAHOUSELAB_ROOT=/opt/dahouselab
CONFIG_ROOT=/srv/dahouselab/config

# --- Service
# Cloudflare API token scoped to Zone -> DNS -> Edit on the ${DOMAIN} zone only.
# Used by the caddy-dns/cloudflare plugin for DNS-01 issuance (ADR-0011).
# Canonical plugin name kept as-is (documented deviation from the service-prefix rule).
CLOUDFLARE_API_TOKEN=
