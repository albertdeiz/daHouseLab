# ==============================================================================
# vaultwarden — environment template
# Copy to `.env` on the host and fill in. NEVER commit `.env`.
# Conventions: docs/standards/environment-variables.md
# ==============================================================================

# --- Platform (values come from the root .env)
TZ=America/Santiago
DOMAIN=dahub.casa
DATA_ROOT=/srv/dahouselab/data

# --- Service
# Open ONLY while creating your own account (deploy runbook step 7-8), then false forever.
SIGNUPS_ALLOWED=false

# Admin panel (/admin) token — LEAVE UNSET to keep the panel disabled (current deployment).
# To enable: argon2 hash via `docker run --rm -it vaultwarden/server:1.34.3 /vaultwarden hash`,
# store the plaintext inside the vault itself, paste the hash here in single quotes.
# ADMIN_TOKEN=''
