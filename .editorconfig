# EditorConfig — https://editorconfig.org
# Consistent formatting across editors. See docs/standards/README.md.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
# Trailing whitespace is meaningful in Markdown (hard line breaks)
trim_trailing_whitespace = false
max_line_length = off

[*.{yml,yaml}]
indent_size = 2

[*.sh]
indent_size = 4

[Makefile]
indent_style = tab

[*.py]
indent_size = 4
