# ==============================================================================
# daHouseLab — Global environment template
#
# Copy to `.env` on the host and fill in real values:
#   cp .env.example .env
#
# NEVER commit `.env`. Only this template lives in Git.
# Naming conventions: docs/standards/environment-variables.md
# ==============================================================================

# ------------------------------------------------------------------------------
# Host identity
# ------------------------------------------------------------------------------
# Short hostname of the current platform host
DAHOUSELAB_HOST=dahouselab

# Timezone for all containers
TZ=America/Santiago

# ------------------------------------------------------------------------------
# Runtime user
# UID/GID that containers run as; must own the config/data directories
# ------------------------------------------------------------------------------
PUID=1000
PGID=1000

# ------------------------------------------------------------------------------
# Networking
# ------------------------------------------------------------------------------
# Base domain for all services (e.g. home.example.com or Tailscale MagicDNS name)
DOMAIN=dahub.casa

# Static LAN IP of the host (documented in docs/network/)
HOST_IP=

# ------------------------------------------------------------------------------
# Storage roots (see docs/standards/storage-and-bind-mounts.md)
# ------------------------------------------------------------------------------
# Version-controlled repository checkout
DAHOUSELAB_ROOT=/opt/dahouselab

# Runtime configuration per service: ${CONFIG_ROOT}/<service>
CONFIG_ROOT=/srv/dahouselab/config

# Application data per service: ${DATA_ROOT}/<service>
DATA_ROOT=/srv/dahouselab/data

# External backup storage (never on the same disk as DATA_ROOT)
BACKUP_ROOT=/mnt/backups
