# daHouseLab — reverse proxy routing table (ADR-0009)
# TLS: Let's Encrypt via DNS-01 against Cloudflare (ADR-0011).
# Mounted read-only into the caddy container; reload procedure in
# docs/runbooks/deploy-caddy.md (step 7). Every change is committed to Git.
{
	email admin@{$DOMAIN}
	acme_dns cloudflare {env.CLOUDFLARE_API_TOKEN}
}

home.{$DOMAIN} {
	reverse_proxy homepage:3000
}

status.{$DOMAIN} {
	reverse_proxy uptime-kuma:3001
}

vault.{$DOMAIN} {
	reverse_proxy vaultwarden:80
}

cloud.{$DOMAIN} {
	redir /.well-known/carddav /remote.php/dav 301
	redir /.well-known/caldav /remote.php/dav 301
	reverse_proxy nextcloud:80
}

# NetAlertX runs in the host network namespace (ADR-0013), so it is reached via
# host.docker.internal (see extra_hosts in services/caddy/compose.yaml), not a
# container name on the proxy network.
net.{$DOMAIN} {
	reverse_proxy host.docker.internal:20211
}

# Site blocks are appended below by each service's deploy runbook, e.g.:
# vault.{$DOMAIN} {
# 	reverse_proxy vaultwarden:80
# }
